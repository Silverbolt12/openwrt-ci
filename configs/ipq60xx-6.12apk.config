# --- 设备平台与 APK 核心配置 ---
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_USE_APK=y
# CONFIG_PACKAGE_opkg is not set
CONFIG_PACKAGE_usign=y
CONFIG_PACKAGE_openwrt-keyring=y
CONFIG_PACKAGE_ca-bundle=y

# --- 核心插件 1：Passwall (科学上网) ---
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_libmbedtls=y

# --- 核心插件 2：SmartDNS 及其加速 ---
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_kmod-tcp-fastopen=y
CONFIG_PACKAGE_libaio=y

# --- 核心插件 3：Lucky / ZeroTier / TTYD / udpxy ---
CONFIG_PACKAGE_lucky=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-i18n-lucky-zh-cn=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-i18n-udpxy-zh-cn=y

# --- 其他保留/新增的功能 ---
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wolplus=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-argon=y

# --- 彻底剔除：USB 网络驱动与相关组件 ---
# CONFIG_PACKAGE_kmod-usb-net is not set
# CONFIG_PACKAGE_kmod-usb-net-rtl8152 is not set
# CONFIG_PACKAGE_kmod-usb-net-asix-ax88179 is not set
# CONFIG_PACKAGE_kmod-usb-net-qmi-wwan is not set
# CONFIG_PACKAGE_kmod-usb-net-cdc-ether is not set
# CONFIG_PACKAGE_usb-modeswitch is not set
# CONFIG_PACKAGE_usbmuxd is not set

# --- 彻底剔除：Docker 及其依赖 ---
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_docker-compose is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_containerd is not set
# CONFIG_PACKAGE_runc is not set

# --- 核心组件 (已精简 USB 与磁盘工具) ---
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_cpufreq=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ip-full=y

# --- LuCI 基础框架 ---
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-proto-relay=y

# --- 系统工具 (保留 SSH 与 固件工具) ---
CONFIG_PACKAGE_openssh-keygen=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_nand-utils=y
CONFIG_PACKAGE_mmc-utils=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_dmesg=y

# --- 彻底剔除不需要的磁盘/USB工具 ---
# CONFIG_PACKAGE_automount is not set
# CONFIG_PACKAGE_blkid is not set
# CONFIG_PACKAGE_fdisk is not set
# CONFIG_PACKAGE_lsblk is not set
# CONFIG_PACKAGE_usbutils is not set
# CONFIG_PACKAGE_usbmuxd is not set

# --- 性能与系统调整 (保留核心部分) ---
CONFIG_CCACHE=y
CONFIG_DEVEL=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_kmod-tun=y

# --- 无线驱动 (按原配置设为 n) ---
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n

# --- 界面与语言 ---
CONFIG_LUCI_LANG_zh_Hans=y
