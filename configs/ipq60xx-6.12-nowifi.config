# --- 目标设备设定：仅保留移动和目 AX18 ---
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y
# 取消多设备编译以节省空间和时间
# CONFIG_TARGET_MULTI_PROFILE is not set

# --- 核心系统：开启 APK 模式 (解决你之前的 Actions 报错) ---
CONFIG_USE_APK=y
# CONFIG_PACKAGE_opkg is not set
CONFIG_PACKAGE_usign=y
CONFIG_PACKAGE_openwrt-keyring=y
CONFIG_PACKAGE_ca-bundle=y

# --- 插件 1：科学上网 (Passwall 核心) ---
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_libmbedtls=y

# --- 插件 2：DNS 加速 (SmartDNS + 内核加速) ---
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_kmod-tcp-fastopen=y
CONFIG_PACKAGE_libaio=y
CONFIG_PACKAGE_librt=y

# --- 插件 3：IPTV 转发 (udpxy) ---
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-i18n-udpxy-zh-cn=y

# --- 其他实用轻量功能 ---
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-i18n-lucky-zh-cn=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-argon-config=y

# --- 性能优化 (NSS 加速 + 16线程跑分) ---
CONFIG_NSS_DRV_IGS_ENABLE=y
CONFIG_NSS_DRV_MAPT_ENABLE=y
CONFIG_NSS_DRV_PPTP_ENABLE=y
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_FIRMWARE_VERSION_12_2=y
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=16
CONFIG_COREMARK_OPTIMIZE_O3=y

# --- 彻底剔除：Docker、USB、WiFi、HomeProxy、其他京东云配置 ---
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_DRIVER_11AX_SUPPORT is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02 is not set

# --- 界面与语言 ---
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-theme-argon=y
